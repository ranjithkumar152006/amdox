# Copy to .env after running: atlas setup
# Get your URI: atlas clusters connectionStrings describe <clusterName>

# Local MongoDB (default) — data persists across server restarts
MONGO_URI=mongodb://127.0.0.1:27017/amdox-erp

# Or MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/amdox-erp?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=your-secret-key-change-in-production
